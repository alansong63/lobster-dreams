    style ControlLayer fill:#fff4e1,stroke:#cc6600,stroke-width:2px
    style Gateway fill:#ffe1e1,stroke:#cc0000,stroke-width:2px
    style Runtime fill:#e1ffe1,stroke:#00cc00,stroke-width:2px
    style Tools fill:#f0e1ff,stroke:#6600cc,stroke-width:2px
    style Storage fill:#fff9e1,stroke:#cc9900,stroke-width:2px
    style Models fill:#e1f0ff,stroke:#0066cc,stroke-width:2px
